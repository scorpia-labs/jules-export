#!/usr/bin/env python3

import argparse
import json
import datetime
import os
import sys
import subprocess
import re

from github import Github
from googleapiclient.discovery import build_from_document
from googleapiclient.errors import HttpError
import httplib2


DISCOVERY_URI = "https://jules.googleapis.com/$discovery/rest?version=v1alpha"


class ApiKeyHttp(httplib2.Http):
    def __init__(self, api_key, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self._api_key = api_key

    def request(self, *args, **kwargs):
        headers = kwargs.setdefault("headers", {})
        headers["X-Goog-Api-Key"] = self._api_key
        return super().request(*args, **kwargs)


def parse_date(date_str):
    try:
        # Assuming format YYYY-MM-DD
        datetime.datetime.strptime(date_str, '%Y-%m-%d')
        return date_str
    except ValueError:
        raise argparse.ArgumentTypeError(
            f"Invalid date format: {date_str!r}. Expected YYYY-MM-DD."
        )


def parse_args():
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument(
        "-k", "--api-key-file",
        default=os.path.expanduser("~/.config/jules/api-key"),
        help="Location to the Jules API key file."
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    # "list" command
    list_parser = subparsers.add_parser("list", help="List sessions.")
    list_parser.add_argument(
        "-s", "--start",
        help="Start date (YYYY-MM-DD)", type=parse_date
    )
    list_parser.add_argument(
        "-e", "--end",
        help="End date (YYYY-MM-DD)", type=parse_date
    )
    list_parser.add_argument(
        "-f", "--filter",
        help="Filter expression to limit the output"
    )

    # "get" command
    get_parser = subparsers.add_parser("get", help="Get a specific session.")
    get_parser.add_argument("session", help="The session ID or name.")

    # "timeline" command
    timeline_parser = subparsers.add_parser(
        "timeline", help="View a unified timeline of activities."
    )
    timeline_parser.add_argument(
        "repo", nargs="?", default=".",
        help=(
            "Local path to the Git repository"
            " (defaults to current directory)."
        )
    )
    timeline_parser.add_argument(
        "-r", "--remote",
        help="The GitHub remote to use. Overrides automatic discovery."
    )
    timeline_parser.add_argument(
        "-g", "--github-key-file",
        default=os.path.expanduser("~/.config/jules/github-key"),
        help="Location to the GitHub API token file."
    )
    timeline_parser.add_argument(
        "-s", "--start",
        help="Start date (YYYY-MM-DD)", type=parse_date
    )
    timeline_parser.add_argument(
        "-e", "--end",
        help="End date (YYYY-MM-DD)", type=parse_date
    )

    return parser.parse_args()


def get_api_key(api_key_file):
    if not os.path.exists(api_key_file):
        print(
            f"Error: API key file not found at {api_key_file}",
            file=sys.stderr
        )
        sys.exit(1)

    with open(api_key_file, "r") as f:
        return f.read().strip()


def create_jules_service(api_key):
    # Fetch discovery document without API key header
    discovery_http = httplib2.Http()
    resp, content_bytes = discovery_http.request(DISCOVERY_URI)
    if resp.status != 200:
        print(
            (
                "Error fetching discovery document:"
                f" {resp.status} - {content_bytes}"
            ),
            file=sys.stderr
        )
        sys.exit(1)
    discovery_http.close()

    discovery_doc = json.loads(content_bytes)
    http = ApiKeyHttp(api_key)
    return build_from_document(discovery_doc, http=http)


def handle_list(service, args):
    sessions = []
    kwargs = {}
    if args.filter:
        kwargs["filter"] = args.filter

    request = service.sessions().list(**kwargs)

    while request is not None:
        response = request.execute()
        sessions.extend(response.get("sessions", []))
        request = service.sessions().list_next(
            previous_request=request, previous_response=response
        )

    filtered_sessions = []
    for session in sessions:
        update_time = session.get("updateTime", "")
        date_str = update_time[:10] if len(update_time) >= 10 else ""

        if args.start and date_str < args.start:
            continue
        if args.end and date_str > args.end:
            continue

        filtered_sessions.append(session)

    print(json.dumps({"sessions": filtered_sessions}))


def handle_get(service, args):
    try:
        response = service.sessions().get(name=args.session).execute()
        print(json.dumps(response))
    except HttpError as e:
        print(f"Error fetching session: {e}", file=sys.stderr)
        sys.exit(1)


def get_github_repo_from_git(repo_path, remote_name=None):
    """Gets the GitHub user/repo string from the local git remote URL."""
    try:
        # Check if the directory is a git repository
        subprocess.run(
            ["git", "rev-parse", "--is-inside-work-tree"],
            cwd=repo_path,
            check=True,
            capture_output=True,
            text=True
        )
    except subprocess.CalledProcessError:
        print(
            f"Error: Directory '{repo_path}' is not a Git repository.",
            file=sys.stderr
        )
        sys.exit(1)
    except FileNotFoundError:
        print(f"Error: Directory '{repo_path}' not found.", file=sys.stderr)
        sys.exit(1)

    if not remote_name:
        try:
            result = subprocess.run(
                ["git", "config", "branch.main.remote"],
                cwd=repo_path,
                check=True,
                capture_output=True,
                text=True
            )
            remote_name = result.stdout.strip()
            print(f"Auto-discovered remote: {remote_name}", file=sys.stderr)
        except subprocess.CalledProcessError:
            print(
                (
                    "Error: Could not automatically determine the remote for the "
                    "'main' branch. Please specify one using -r/--remote."
                ),
                file=sys.stderr
            )
            sys.exit(1)

    try:
        result = subprocess.run(
            ["git", "remote", "get-url", remote_name],
            cwd=repo_path,
            check=True,
            capture_output=True,
            text=True
        )
        url = result.stdout.strip()
    except subprocess.CalledProcessError:
        print(
            (
                f"Error: Could not determine '{remote_name}' remote URL."
                " Make sure the remote exists."
            ),
            file=sys.stderr
        )
        sys.exit(1)

    # Parse standard GitHub URLs
    # https://github.com/user/repo.git
    # git@github.com:user/repo.git
    match = re.search(r"^(?:https://github\.com/|git@github\.com:)(.+?/.+?)(?:\.git)?$", url)
    if not match:
        print(
            (
                f"Error: Remote '{remote_name}' URL '{url}' does not appear to be"
                " a valid GitHub repository."
            ),
            file=sys.stderr
        )
        sys.exit(1)

    return match.group(1)


def get_jules_events(service, repo_name, start_date, end_date):
    """Fetches and formats session events from Jules API."""
    events = []

    target_source = f"sources/github/{repo_name}"

    request = service.sessions().list()
    sessions = []

    while request is not None:
        try:
            response = request.execute()
            sessions.extend(response.get("sessions", []))
            request = service.sessions().list_next(
                previous_request=request, previous_response=response
            )
        except HttpError as e:
            print(
                f"Warning: Could not fetch Jules sessions: {e}",
                file=sys.stderr
            )
            break

    for session in sessions:
        # Filter by repo
        source_context = session.get("sourceContext", {})
        if source_context.get("source") != target_source:
            continue

        update_time = session.get("updateTime", "")
        # Filter by date
        if update_time:
            date_str = update_time[:10]
            if start_date and date_str < start_date:
                continue
            if end_date and date_str > end_date:
                continue

        # Populate references
        references = {
            "jules": [session.get("name")],
            "github": [],
            "git": []
        }

        outputs = session.get("outputs", [])
        for output in outputs:
            # Extract GitHub PR reference
            pr_url = output.get("pullRequest", {}).get("url")
            if pr_url:
                # e.g. https://github.com/owner/repo/pull/123
                pr_match = re.search(r"pull/(\d+)$", pr_url)
                if pr_match:
                    references["github"].append(int(pr_match.group(1)))

            # Extract Git commit reference
            change_set = output.get("changeSet", {})
            base_commit_id = change_set.get("baseCommitId")
            if base_commit_id:
                references["git"].append(base_commit_id)

        # Deduplicate references
        references["github"] = list(set(references["github"]))
        references["git"] = list(set(references["git"]))

        events.append({
            "timestamp": update_time,
            "source": "jules",
            "type": "session",
            "actor": "jules",
            "description": f"Jules Session: {session.get('name')}",
            "id": session.get("name"),
            "references": references
        })

    return events


def normalize_timestamp(ts_str):
    """Normalizes an ISO 8601 string to strict UTC format:
    YYYY-MM-DDTHH:MM:SSZ
    """
    if not ts_str:
        return ""
    # E.g. 2026-07-07T01:38:38-04:00 (from git)
    # E.g. 2026-07-07T05:38:38Z (from github)
    # Python datetime.fromisoformat can handle this in >=3.7
    # However it might not handle the 'Z' suffix nicely in 3.10 and below.
    # Replace 'Z' with '+00:00' to be safe.
    ts_str_clean = ts_str.replace("Z", "+00:00")
    try:
        dt = datetime.datetime.fromisoformat(ts_str_clean)
        # Convert to UTC
        dt_utc = dt.astimezone(datetime.timezone.utc)
        return dt_utc.strftime('%Y-%m-%dT%H:%M:%SZ')
    except ValueError:
        return ts_str


def get_git_events(repo_path, start_date, end_date):
    """Fetches and formats commit events from local git."""
    events = []

    # We want: timestamp(ISO-8601), hash, author name, subject message
    # Format: %cI = committer date, strict ISO 8601 format
    # %H = commit hash, %an = author name, %s = subject
    # We use a custom delimiter `|||` to split safely
    cmd = ["git", "log", "--format=%cI|||%H|||%an|||%s"]

    if start_date:
        # git log accepts --since="YYYY-MM-DD"
        cmd.append(f"--since={start_date}")
    if end_date:
        # git log accepts --until="YYYY-MM-DD"
        cmd.append(f"--until={end_date}")

    try:
        result = subprocess.run(
            cmd,
            cwd=repo_path,
            check=True,
            capture_output=True,
            text=True
        )
    except subprocess.CalledProcessError as e:
        print(f"Warning: Could not fetch git logs: {e}", file=sys.stderr)
        return events

    for line in result.stdout.strip().split("\n"):
        if not line:
            continue

        parts = line.split("|||", 3)
        if len(parts) != 4:
            continue

        timestamp, commit_hash, author, subject = parts

        # We enforce UTC normalization below in sorting anyway, but git gives
        # %cI which is ISO 8601 (e.g. 2023-10-01T12:00:00+02:00)
        # We can store it as is, and let the normalizer handle it later, or
        # try to parse it. Let's just store the string.

        # Look for PR numbers in commit message (e.g. #123)
        pr_matches = re.findall(r"#(\d+)", subject)
        github_refs = [int(pr) for pr in pr_matches]

        events.append({
            "timestamp": timestamp,
            "source": "git",
            "type": "commit",
            "actor": author,
            "description": f"Commit: {subject}",
            "id": commit_hash,
            "references": {
                "git": [commit_hash],
                "github": list(set(github_refs)),
                "jules": []
            }
        })

    return events


def get_github_events(github_token, repo_name, start_date, end_date):
    """Fetches and formats PR events from GitHub."""
    events = []

    if not github_token:
        # Fallback to unauthenticated if token not provided or fails to read
        g = Github()
    else:
        g = Github(github_token)

    try:
        repo = g.get_repo(repo_name)
        # We need to fetch both open and closed PRs to get a full timeline
        # Sort by updated descending so we capture recently closed/merged PRs
        # even if they were created long ago.
        prs = repo.get_pulls(state="all", sort="updated", direction="desc")

        for pr in prs:
            if start_date:
                updated_date_str = pr.updated_at.strftime('%Y-%m-%d')
                if updated_date_str < start_date:
                    # Since PRs are sorted by updated descending, once we hit
                    # one older than start date, we can stop querying
                    break

            # Opened event
            events.append({
                "timestamp": pr.created_at.strftime('%Y-%m-%dT%H:%M:%SZ'),
                "source": "github",
                "type": "pr_opened",
                "actor": pr.user.login,
                "description": f"Opened PR: {pr.title}",
                "id": pr.number,
                "references": {
                    "jules": [],
                    "github": [pr.number],
                    "git": []
                }
            })

            # Merged/Closed event
            if pr.closed_at:
                event_type = "pr_merged" if pr.merged_at else "pr_closed"
                closed_timestamp = (
                    pr.merged_at if pr.merged_at else pr.closed_at
                )
                events.append({
                    "timestamp": closed_timestamp.strftime(
                        '%Y-%m-%dT%H:%M:%SZ'
                    ),
                    "source": "github",
                    "type": event_type,
                    "actor": (
                        pr.merged_by.login
                        if (pr.merged_at and pr.merged_by)
                        else pr.user.login
                    ),
                    "description": (
                        f"{'Merged' if pr.merged_at else 'Closed'}"
                        f" PR: {pr.title}"
                    ),
                    "id": pr.number,
                    "references": {
                        "jules": [],
                        "github": [pr.number],
                        "git": (
                            [pr.merge_commit_sha]
                            if pr.merge_commit_sha
                            else []
                        )
                    }
                })
    except Exception as e:
        print(
            f"Warning: Could not fetch GitHub PRs for {repo_name}: {e}",
            file=sys.stderr
        )

    return events


def handle_timeline(service, args):
    repo_name = get_github_repo_from_git(args.repo, args.remote)

    github_token = None
    if os.path.exists(args.github_key_file):
        with open(args.github_key_file, "r") as f:
            github_token = f.read().strip()
    elif args.github_key_file != os.path.expanduser(
        "~/.config/jules/github-key"
    ):
        print(
            f"Error: GitHub key file not found at {args.github_key_file}",
            file=sys.stderr
        )
        sys.exit(1)

    all_events = []

    # 1. Fetch GitHub events
    github_events = get_github_events(
        github_token, repo_name, args.start, args.end
    )
    all_events.extend(github_events)

    # 2. Fetch Jules events
    jules_events = get_jules_events(service, repo_name, args.start, args.end)
    all_events.extend(jules_events)

    # 3. Fetch Git events
    git_events = get_git_events(args.repo, args.start, args.end)
    all_events.extend(git_events)

    # 4. Normalize timestamps and filter just in case
    normalized_events = []
    for event in all_events:
        event["timestamp"] = normalize_timestamp(event.get("timestamp"))

        # Double check date filters for normalized events
        date_str = event["timestamp"][:10] if event["timestamp"] else ""
        if args.start and date_str < args.start:
            continue
        if args.end and date_str > args.end:
            continue

        normalized_events.append(event)

    # 5. Sort newest to oldest
    normalized_events.sort(key=lambda x: x.get("timestamp", ""), reverse=True)

    print(json.dumps(normalized_events))


def main():
    args = parse_args()

    api_key = get_api_key(args.api_key_file)
    service = create_jules_service(api_key)

    if args.command == "list":
        handle_list(service, args)
    elif args.command == "get":
        handle_get(service, args)
    elif args.command == "timeline":
        handle_timeline(service, args)


if __name__ == "__main__":
    main()
